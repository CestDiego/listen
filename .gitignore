.DS_Store
node_modules/
dist/
.env
.env.local
.env.production
bin/
.tmp/
.build/
.swiftpm/
*.bak.*
/tmp/

# Python / experts pipeline
experts/.venv/
experts/uv.lock
__pycache__/
*.pyc

# MLX trained model weights (regenerated by start.sh / experts:train)
experts/models/*/adapters.safetensors/

# NRC VAD Lexicon (non-redistributable — download from saifmohammad.com)
data/nrc-vad/

# HuggingFace training datasets (large, reproducible via scripts/download-datasets.py)
data/clinc-oos/
data/massive/
data/snips/
data/banking77/

# Augmented training data (regenerated by scripts/map-datasets.py)
experts/data/multitool-augmented/

# Playlist audio files (downloaded locally, not committed)
data/playlists/*/[0-9]*.opus
data/playlists/*/[0-9]*.mp3
data/playlists/*/[0-9]*.m4a
data/playlists/*/*.info.json
